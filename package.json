{
  "name": "retina-client",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev -p $(node -e \"import('./next.config.mjs').then(c=>console.log(c.default.env.RETINA_PORT||3333))\")",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "bash deploy.sh",
    "deploy:dry": "bash deploy.sh --dry-run"
  },
  "dependencies": {
    "@rodrigo-barraza/components": "github:rodrigo-barraza/components",
    "@rodrigo-barraza/utilities": "github:rodrigo-barraza/utilities",
